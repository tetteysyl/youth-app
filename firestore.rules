rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getMember() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getMember().role == role;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && getMember().role in roles;
    }

    function isApproved() {
      return isSignedIn() && getMember().role != 'pending' && getMember().role != 'rejected';
    }

    function isManagement() {
      return hasAnyRole([
        'president', 'financial_secretary', 'treasurer',
        'evangelism_coordinator', 'male_organizer', 'female_organizer'
      ]);
    }

    function isOrganizer() {
      return hasAnyRole(['president', 'male_organizer', 'female_organizer']);
    }

    function isFinance() {
      return hasAnyRole(['president', 'financial_secretary', 'treasurer']);
    }

    function isEvangelism() {
      return hasAnyRole(['president', 'evangelism_coordinator']);
    }

    // ── Members ────────────────────────────────────────────────────────────────
    match /members/{userId} {
      // Anyone can create their own member doc on registration
      allow create: if request.auth.uid == userId;

      // Members can read their own profile; management can read all
      allow read: if request.auth.uid == userId || isManagement();

      // Only president can update roles; members can update their own non-role fields
      allow update: if
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        hasRole('president');

      // No deletion allowed
      allow delete: if false;
    }

    // ── Events ─────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isApproved();
      allow create, update, delete: if isOrganizer();
    }

    // ── Meetings ───────────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read: if isApproved();
      allow create: if isOrganizer();
      allow update: if isOrganizer(); // attendance updates, status changes
      allow delete: if hasRole('president');
    }

    // ── Finance ────────────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isFinance();
      allow create, update: if isFinance();
      allow delete: if hasRole('president');
    }

    // ── Bible Quotes / Evangelism ──────────────────────────────────────────────
    match /bible_quotes/{quoteId} {
      allow read: if isApproved();
      allow create: if isEvangelism();
      allow delete: if hasRole('president');
    }

    // ── Broadcasts ─────────────────────────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if isApproved();
      allow create: if hasRole('president');
      allow delete: if hasRole('president');
    }

    // ── Notifications (internal) ───────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if isManagement();
      allow update: if request.auth.uid == resource.data.userId; // mark as read
      allow delete: if false;
    }
  }
}
