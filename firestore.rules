rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getMember() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getMember().role == role;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && getMember().role in roles;
    }

    function isApproved() {
      return isSignedIn() && getMember().role != 'pending' && getMember().role != 'rejected';
    }

    // The system-owner role. It is a member of every permission group below, so all
    // existing checks keep working and simply also return true for the super admin.
    function isOwner() {
      return isSignedIn() && getMember().role == 'super_admin';
    }

    function isOrganizer() {
      return hasAnyRole(['super_admin', 'president', 'male_organizer', 'female_organizer']);
    }

    function isFinance() {
      return hasAnyRole(['super_admin', 'president', 'financial_secretary', 'treasurer']);
    }

    function isEvangelism() {
      return hasAnyRole(['super_admin', 'president', 'evangelism_coordinator']);
    }

    // ── Members ────────────────────────────────────────────────────────────────
    match /members/{userId} {
      // A user may create ONLY their own doc, and only as a pending member.
      // This prevents a client from self-assigning a privileged role at sign-up
      // (e.g. writing role: 'president' straight into Firestore).
      allow create: if request.auth.uid == userId
        && request.resource.data.role == 'pending';

      // A member may read ONLY their own doc directly. Every view of other members
      // (directory, admin panel, cell/evangelism member pickers, messaging peers)
      // goes through the API, which returns data filtered by the caller's role and
      // strips PII (dateOfBirth, gender, phone) for non-privileged roles. This makes
      // it impossible to pull another member's private fields straight from Firestore.
      allow read: if request.auth.uid == userId;

      // Members may update only their own NON-privileged fields. Role and the
      // lifecycle/approval fields are server-managed (set via the admin API using
      // the Admin SDK, which bypasses these rules) and must never be self-written —
      // otherwise a member could grant themselves a role, fake approval, or reset
      // their YAF countdown to dodge auto-removal.
      // The super_admin (owner) role is managed ONLY by the setup script (Admin SDK,
      // which bypasses these rules). No client write may grant it or alter an existing
      // owner doc — this closes a path where a president could self-escalate to owner by
      // writing role:'super_admin' straight to Firestore.
      allow update: if
        (
          (request.auth.uid == userId &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isYaf', 'yafStartedAt', 'approvedAt', 'approvedBy', 'removalWarningSent'])) ||
          (isOwner() || hasRole('president'))
        )
        && resource.data.role != 'super_admin'
        && request.resource.data.role != 'super_admin';

      // No deletion allowed (handled server-side via Admin SDK).
      allow delete: if false;
    }

    // ── Events ─────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isApproved();
      allow create, update, delete: if isOrganizer();
    }

    // ── Meetings ───────────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read: if isApproved();
      allow create: if isOrganizer();
      allow update: if isOrganizer(); // attendance updates, status changes
      allow delete: if (isOwner() || hasRole('president'));
    }

    // ── Finance ────────────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isFinance();
      allow create, update: if isFinance();
      allow delete: if (isOwner() || hasRole('president'));
    }

    // ── Bible Quotes / Evangelism ──────────────────────────────────────────────
    match /bible_quotes/{quoteId} {
      allow read: if isApproved();
      allow create: if isEvangelism();
      allow delete: if (isOwner() || hasRole('president'));
    }

    // ── Broadcasts ─────────────────────────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if isApproved();
      allow create: if (isOwner() || hasRole('president'));
      allow delete: if (isOwner() || hasRole('president'));
    }

    // ── Notifications (internal) ───────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isApproved() && request.auth.uid == resource.data.userId;
      // Notifications are only ever created server-side (Admin SDK, which bypasses
      // rules). Blocking client creates stops a member from spoofing notifications
      // to other users.
      allow create: if false;
      // A user may only mark their own notifications read / delete their own.
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ── Financial Statements ───────────────────────────────────────────────────
    match /financial_statements/{stmtId} {
      allow read: if isApproved();
      allow create, update: if isFinance();
      allow delete: if (isOwner() || hasRole('president'));
    }

    // ── Messages ───────────────────────────────────────────────────────────────
    match /messages/{msgId} {
      // Group messages are visible to all approved members. Direct messages are
      // visible ONLY to their two participants — previously any approved member
      // could read every private conversation in the guild.
      // The super admin (owner) takes no part in messaging — excluded from all reads.
      allow read: if isApproved() && !isOwner() && (
        resource.data.type == 'group' ||
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.recipientId
      );
      // A client may only send a message AS itself (senderId must match the caller),
      // preventing forged/impersonated messages. Role checks for group messages are
      // enforced by the API. The super admin cannot send at all.
      allow create: if isApproved() && !isOwner() && request.resource.data.senderId == request.auth.uid;
      allow delete: if request.auth.uid == resource.data.senderId;
    }

    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
